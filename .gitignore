# ==============================================================================
# .gitignore for the space_sim repo
# Covers the Unity project at SPACESIM/ plus general repo-level ignores.
# ==============================================================================

# ------------------------------------------------------------------------------
# Unity project ignores
# These apply to any Unity project subdirectory in the repo (currently SPACESIM/).
# Library, Temp, Logs, etc. are Unity's caches and are regenerated on project
# open — never commit them.
# ------------------------------------------------------------------------------

# Unity caches and intermediate files
**/Library/
**/Temp/
**/Logs/
**/UserSettings/
**/MemoryCaptures/
**/obj/
**/_Recovery/

# Unity build outputs
**/Build/
**/Builds/

# Asset Store tools and packages
**/Assets/AssetStoreTools*

# Visual Studio / Rider / VS Code auto-generated solution and project files
# These are regenerated by Unity on each project open.
**/*.csproj
**/*.sln
**/*.slnx
**/*.suo
**/*.tmp
**/*.user
**/*.userprefs
**/*.pidb
**/*.booproj
**/*.svd
**/*.pdb
**/*.mdb
**/*.opendb
**/*.VC.db
**/sysinfo.txt

# Unity Crashlytics generated file
**/crashlytics-build.properties

# Unity packed asset / package files
**/*.apk
**/*.aab
**/*.unitypackage
**/*.app

# IDE workspace folders
**/.vscode/
**/.vs/
**/.idea/

# ------------------------------------------------------------------------------
# OS-specific files
# ------------------------------------------------------------------------------

# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
**/Thumbs.db
ehthumbs.db
desktop.ini
**/desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------------------------
# Backups and editor swap files
# ------------------------------------------------------------------------------
*.bak
*.swp
*.swo
*~
*.orig

# ------------------------------------------------------------------------------
# Recovery files from the bash-via-Python escape-hatch write pattern
# (see commits/README.md for the workflow rule context)
# ------------------------------------------------------------------------------
*.recovery
